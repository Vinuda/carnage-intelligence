<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Carnage — Brand Intelligence Dashboard</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=Cabinet+Grotesk:wght@800;900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg-base:        #000000;
    --bg-surface:     #0a0a0a;
    --bg-card:        #0d0d0d;
    --bg-card-hover:  #121212;
    --border-dim:     #1a1a1a;
    --border-bright:  #2d2d2d;
    --accent-red:     #e8341c;
    --text-primary:   #ffffff;
    --text-secondary: #a3a3a3;
    --text-dim:       #525252;
    --positive:       #00ff66;
    --neutral:        #ffaa00;
    --negative:       #ff3333;
    --radius-sm:      0px; /* Shifted to sharp corners to match incarnage.com layout */
    --radius-md:      0px;
    --radius-lg:      0px;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg-base);
    color: var(--text-primary);
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    line-height: 1.6;
    min-height: 100vh;
    letter-spacing: -0.01em;
  }

  /* ─── OFFICIAL HEADER STYLE ─────────────────────────────────── */
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: #000000;
    border-bottom: 1px solid var(--border-dim);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 40px;
    height: 70px;
  }

  .logo-block {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .logo-text {
    font-family: 'Cabinet Grotesk', sans-serif;
    font-weight: 900;
    font-size: 24px;
    letter-spacing: 0.08em;
    color: var(--text-primary);
  }

  .logo-sub {
    font-size: 10px;
    font-weight: 600;
    color: var(--text-secondary);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    border-left: 1px solid var(--border-bright);
    padding-left: 16px;
    margin-left: 4px;
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .view-toggle {
    display: flex;
    align-items: center;
    background: #111;
    border: 1px solid var(--border-bright);
    border-radius: 0px;
  }

  .view-btn {
    padding: 8px 20px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    border: none;
    background: transparent;
    color: var(--text-secondary);
    transition: all 0.2s ease;
  }

  .view-btn.active {
    background: var(--text-primary);
    color: #000000;
  }

  .header-date {
    font-size: 10px;
    font-weight: 600;
    color: var(--text-dim);
    letter-spacing: 0.15em;
  }

  /* ─── MAIN LAYOUT ─────────────────────────────────────────────── */
  main {
    max-width: 1500px;
    margin: 0 auto;
    padding: 40px 40px 100px;
  }

  /* ─── BRAND SLOGAN BAR ────────────────────────────────────────── */
  .slogan-banner {
    background: #0d0d0d;
    border: 1px solid var(--border-dim);
    padding: 12px 24px;
    margin-bottom: 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .slogan-text {
    font-family: 'Cabinet Grotesk', sans-serif;
    font-weight: 900;
    font-size: 14px;
    letter-spacing: 0.3em;
    color: var(--text-primary);
    text-transform: uppercase;
  }
  .slogan-tag {
    font-size: 11px;
    color: var(--accent-red);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 700;
  }

  /* ─── SECTION LABELS ───────────────────────────────────────────── */
  .section-label {
    display: flex;
    align-items: center;
    margin-bottom: 24px;
  }

  .section-label span {
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-primary);
  }

  .section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border-dim);
    margin-left: 20px;
  }

  /* ─── EXECUTIVE BRIEF ─────────────────────────────────────────── */
  .exec-summary {
    background: var(--bg-surface);
    border: 1px solid var(--border-bright);
    padding: 40px;
    margin-bottom: 48px;
  }

  .exec-summary h2 {
    font-family: 'Cabinet Grotesk', sans-serif;
    font-weight: 900;
    font-size: 28px;
    letter-spacing: 0.02em;
    margin-bottom: 20px;
    text-transform: uppercase;
  }

  .exec-summary p {
    color: var(--text-secondary);
    font-size: 14px;
    max-width: 1050px;
    line-height: 1.8;
  }

  .exec-summary p + p { margin-top: 16px; }

  .exec-highlight {
    display: inline;
    color: #ffffff;
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-color: var(--accent-red);
  }

  /* ─── STARK GRID SYSTEM ───────────────────────────────────────── */
  .hero-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border-dim);
    border: 1px solid var(--border-dim);
    margin-bottom: 48px;
  }

  .metric-card {
    background: var(--bg-base);
    padding: 32px;
    transition: background 0.2s ease;
  }

  .metric-card:hover {
    background: var(--bg-card);
  }

  .metric-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .metric-value {
    font-family: 'Cabinet Grotesk', sans-serif;
    font-weight: 900;
    font-size: 48px;
    line-height: 1;
    letter-spacing: -0.02em;
    margin-bottom: 12px;
  }

  .metric-value .unit {
    font-size: 20px;
    font-weight: 800;
    color: var(--text-secondary);
    margin-left: 4px;
    font-family: 'Cabinet Grotesk', sans-serif;
  }

  .metric-sub {
    font-size: 12px;
    color: var(--text-secondary);
  }

  .trend-up { color: var(--positive); font-weight: 600; }
  .trend-down { color: var(--negative); font-weight: 600; }

  /* ─── CHARTS CONFIGURATION ────────────────────────────────────── */
  .charts-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    margin-bottom: 32px;
  }

  .charts-grid.full { grid-template-columns: 1fr; }

  .chart-card {
    background: var(--bg-surface);
    border: 1px solid var(--border-dim);
    padding: 36px;
  }

  .chart-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 24px;
  }

  .chart-title {
    font-family: 'Cabinet Grotesk', sans-serif;
    font-weight: 900;
    font-size: 20px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .chart-subtitle {
    font-size: 12px;
    color: var(--text-secondary);
    margin-top: 4px;
  }

  .chart-badge {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 6px 14px;
    border: 1px solid var(--border-bright);
    color: #ffffff;
    background: #000000;
  }

  .chart-wrap {
    position: relative;
    margin-top: 24px;
  }

  /* ─── STARK DATA TABLE ────────────────────────────────────────── */
  .data-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 16px;
  }

  .data-table th {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-dim);
    padding: 16px 20px;
    text-align: left;
    border-bottom: 2px solid var(--border-bright);
    background: #050505;
  }

  .data-table td {
    padding: 18px 20px;
    font-size: 13px;
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border-dim);
  }

  .data-table tr:hover td { 
    background: #111111; 
    color: #ffffff;
  }

  .brand-name-cell {
    font-family: 'Cabinet Grotesk', sans-serif;
    font-weight: 900;
    font-size: 15px;
    color: var(--text-primary);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .pill {
    display: inline-block;
    padding: 4px 12px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.05em;
    border: 1px solid transparent;
  }

  .pill-green  { border-color: var(--positive); color: var(--positive); background: rgba(0,255,102,0.05); }
  .pill-yellow { border-color: var(--neutral);  color: var(--neutral);  background: rgba(255,170,0,0.05); }
  .pill-red    { border-color: var(--negative); color: var(--negative); background: rgba(255,51,51,0.05); }

  /* ─── INSIGHTS ────────────────────────────────────────────────── */
  .insight-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border-dim);
    margin-top: 32px;
  }

  .insight-chip {
    background: var(--bg-base);
    padding: 20px;
  }

  .insight-chip .ic-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 6px;
  }

  .insight-chip .ic-value {
    font-family: 'Cabinet Grotesk', sans-serif;
    font-weight: 900;
    font-size: 22px;
  }

  .insight-chip .ic-delta {
    font-size: 12px;
    color: var(--positive);
    margin-top: 2px;
  }

  .legend {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    margin-top: 24px;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .legend-dot {
    width: 10px;
    height: 3px;
  }

  /* ─── FOOTER ──────────────────────────────────────────────────── */
  footer {
    border-top: 1px solid var(--border-dim);
    padding: 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  @media (max-width: 1024px) {
    main { padding: 24px 20px; }
    header { padding: 0 20px; }
    .hero-grid { grid-template-columns: 1fr; }
    .charts-grid { grid-template-columns: 1fr; }
    .insight-row { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>

<header>
  <div class="logo-block">
    <div class="logo-text">CARNAGE</div>
    <div class="logo-sub">Intelligence Platform</div>
  </div>
  <div class="header-right">
    <div class="view-toggle">
      <button class="view-btn active" id="btn-global" onclick="setView('global')">Global Matrix</button>
      <button class="view-btn" id="btn-domestic" onclick="setView('domestic')">Domestic Only</button>
    </div>
    <div class="header-date" id="header-date"></div>
  </div>
</header>

<main>

  <div class="slogan-banner">
    <div class="slogan-text">BE RELENTLESS</div>
    <div class="slogan-tag">Competitive Intelligence Architecture</div>
  </div>

  <div class="section-label"><span>01 / Executive Overview</span></div>
  <div class="exec-summary">
    <h2>Strategic Positioning Status — Q2 2025</h2>
    <p>
      Carnage has carved out a premium standing, capturing a <span class="exec-highlight">Net Sentiment Score of +84</span>. This trajectory places the brand uniquely high across regional activewear frameworks, anchored directly by calculated drops, specialized aesthetics, and highly authentic consumer relationships.
    </p>
    <p>
      Domestically, Carnage leads traditional alternatives across perceived hype indexes and asset styling choices. From a global outlook, the data reveals a defined landscape: an opportunity to solidify lifestyle-oriented performance pieces scaling cleanly beneath Lululemon and Gymshark. 
    </p>
  </div>

  <div class="section-label"><span>02 / Core Analytics Matrix</span></div>
  <div class="hero-grid">
    <div class="metric-card">
      <div class="metric-label">Net Sentiment Score</div>
      <div class="metric-value">+84<span class="unit">/100</span></div>
      <div class="metric-sub"><span class="trend-up">▲ 12pts</span> vs market baseline</div>
    </div>
    <div class="metric-card">
      <div class="metric-label">Domestic Share Est.</div>
      <div class="metric-value">7.2<span class="unit">%</span></div>
      <div class="metric-sub"><span class="trend-up">▲ 3.1% YoY</span> premium window</div>
    </div>
    <div class="metric-card">
      <div class="metric-label">Social Engagement</div>
      <div class="metric-value">3.4<span class="unit">×</span></div>
      <div class="metric-sub">Sustained premium benchmark</div>
    </div>
    <div class="metric-card">
      <div class="metric-label">Avg Drop Sell-Through</div>
      <div class="metric-value">91<span class="unit">%</span></div>
      <div class="metric-sub"><span class="trend-up">Top tier</span> drop velocity metrics</div>
    </div>
    <div class="metric-card">
      <div class="metric-label">Flagship Store NPS</div>
      <div class="metric-value">+71<span class="unit"></span></div>
      <div class="metric-sub">Calculated storefront index</div>
    </div>
    <div class="metric-card">
      <div class="metric-label">Earned Media Value</div>
      <div class="metric-value">4.8M<span class="unit">LKR</span></div>
      <div class="metric-sub">Organic scaling reach metrics</div>
    </div>
  </div>

  <div class="section-label"><span>03 / Brand Performance Mapping</span></div>
  <div class="charts-grid">

    <div class="chart-card">
      <div class="chart-header">
        <div>
          <div class="chart-title">Brand Vector Metrics</div>
          <div class="chart-subtitle">5-point configuration tracking core brand parameters</div>
        </div>
        <div class="chart-badge" id="radar-badge">Full Matrix</div>
      </div>
      <div class="chart-wrap" style="height:320px">
        <canvas id="radarChart"></canvas>
      </div>
      <div class="legend" id="radar-legend"></div>
    </div>

    <div class="chart-card">
      <div class="chart-header">
        <div>
          <div class="chart-title">Direct Channel Sentiment</div>
          <div class="chart-subtitle">Calculated signals cross-referenced by visibility platforms</div>
        </div>
        <div class="chart-badge" id="bar-badge">Focus Array</div>
      </div>
      <div class="chart-wrap" style="height:250px">
        <canvas id="barChart"></canvas>
      </div>
      <div class="insight-row">
        <div class="insight-chip">
          <div class="ic-label">Instagram</div>
          <div class="ic-value">88%</div>
          <div class="ic-delta">Positive signal</div>
        </div>
        <div class="insight-chip">
          <div class="ic-label">TikTok</div>
          <div class="ic-value">79%</div>
          <div class="ic-delta">Positive signal</div>
        </div>
        <div class="insight-chip">
          <div class="ic-label">Flagship Store</div>
          <div class="ic-value">93%</div>
          <div class="ic-delta">Positive signal</div>
        </div>
      </div>
    </div>

  </div>

  <div class="charts-grid full">
    <div class="chart-card">
      <div class="chart-header">
        <div>
          <div class="chart-title">Global Placement Mapping</div>
          <div class="chart-subtitle" id="bubble-sub">Pricing structural scale vs Product Application focus</div>
        </div>
        <div class="chart-badge">Strategic Grid</div>
      </div>
      <div class="chart-wrap" style="height:440px">
        <canvas id="bubbleChart"></canvas>
      </div>
      <div class="legend" id="bubble-legend"></div>
    </div>
  </div>

  <div class="section-label"><span>04 / Comparative Dataset</span></div>
  <div class="chart-card" style="padding:0px; background: transparent; border: 1px solid var(--border-dim);">
    <table class="data-table">
      <thead>
        <tr>
          <th>Brand Space</th>
          <th>Classification</th>
          <th>Price Architecture</th>
          <th>NSI Rank</th>
          <th>Reach Metric</th>
          <th>Community</th>
          <th>Vector Alignment</th>
        </tr>
      </thead>
      <tbody id="table-body"></tbody>
    </table>
  </div>

</main>

<footer>
  <span>CONFIDENTIAL — CARNAGE BRAND INTELLIGENCE PLATFORM</span>
  <span>DATA LAYER: VERIFIED ANALYTICS SNAPSHOT 2025</span>
</footer>

<script>
const DATA = {
  brands: [
    {
      name: 'Carnage',
      category: 'Local — Premium',
      priceTier: 'LKR 3,500–8,000',
      nsi: 84,
      followers: '28K',
      community: 'High',
      positioning: 'Lifestyle-Performance',
      color: '#e8341c',
      pillars: [88, 72, 90, 95, 85],
      sentimentIG:    [88, 7, 5],
      sentimentTT:    [79, 14, 7],
      sentimentStore: [93, 5, 2],
      bubble: { x: 38, y: 68, r: 22 },
      global: true, domestic: true
    },
    {
      name: 'Gymshark',
      category: 'Global Leader',
      priceTier: 'USD 40–85',
      nsi: 76,
      followers: '6.5M',
      community: 'High',
      positioning: 'Performance-Led',
      color: '#ffffff',
      pillars: [85, 68, 80, 88, 55],
      sentimentIG:    [82, 12, 6],
      sentimentTT:    [74, 18, 8],
      sentimentStore: [60, 28, 12],
      bubble: { x: 72, y: 42, r: 30 },
      global: true, domestic: false
    },
    {
      name: 'YoungLA',
      category: 'Global Leader',
      priceTier: 'USD 35–75',
      nsi: 68,
      followers: '1.2M',
      community: 'High',
      positioning: 'Lifestyle Hype',
      color: '#a3a3a3',
      pillars: [74, 78, 72, 92, 48],
      sentimentIG:    [76, 16, 8],
      sentimentTT:    [69, 20, 11],
      sentimentStore: [54, 30, 16],
      bubble: { x: 65, y: 76, r: 24 },
      global: true, domestic: false
    },
    {
      name: 'Lululemon',
      category: 'Global Premium',
      priceTier: 'USD 80–160',
      nsi: 71,
      followers: '5.2M',
      community: 'Medium',
      positioning: 'Premium Lifestyle',
      color: '#525252',
      pillars: [96, 42, 64, 70, 90],
      sentimentIG:    [78, 16, 6],
      sentimentTT:    [62, 24, 14],
      sentimentStore: [84, 12, 4],
      bubble: { x: 92, y: 88, r: 28 },
      global: true, domestic: false
    },
    {
      name: 'Envoy Sport',
      category: 'Local Alternate',
      priceTier: 'LKR 1,800–4,500',
      nsi: 42,
      followers: '11K',
      community: 'Medium',
      positioning: 'Value Performance',
      color: '#262626',
      pillars: [60, 80, 48, 40, 55],
      sentimentIG:    [56, 28, 16],
      sentimentTT:    [48, 32, 20],
      sentimentStore: [62, 24, 14],
      bubble: { x: 20, y: 38, r: 12 },
      global: false, domestic: true
    },
    {
      name: 'FOA',
      category: 'Local Alternate',
      priceTier: 'LKR 2,000–5,500',
      nsi: 38,
      followers: '8.5K',
      community: 'Low-Med',
      positioning: 'Functional Basic',
      color: '#404040',
      pillars: [58, 74, 42, 35, 50],
      sentimentIG:    [52, 30, 18],
      sentimentTT:    [44, 36, 20],
      sentimentStore: [58, 28, 14],
      bubble: { x: 22, y: 28, r: 10 },
      global: false, domestic: true
    }
  ],
  pillars: ['Product Quality', 'Price-Value Tier', 'Community Density', 'Hype Activation', 'Retail Experience']
};

let currentView = 'global';
let charts = {};

function filteredBrands() {
  if (currentView === 'global') return DATA.brands;
  return DATA.brands.filter(b => b.domestic);
}

document.getElementById('header-date').textContent =
  new Date().toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' }).toUpperCase();

// Chart System Configuration Parameters
Chart.defaults.color = '#737373';
Chart.defaults.font.family = 'Inter, sans-serif';
Chart.defaults.font.size = 11;
const gridColor = '#1a1a1a';
const tickColor = '#525252';

function buildRadar() {
  const brands = filteredBrands();
  document.getElementById('radar-badge').textContent = currentView === 'global' ? 'Full Matrix' : 'Domestic Array';

  const datasets = brands.map(b => ({
    label: b.name,
    data: b.pillars,
    borderColor: b.color,
    backgroundColor: 'transparent',
    borderWidth: b.name === 'Carnage' ? 3 : 1,
    pointBackgroundColor: b.color,
    pointRadius: b.name === 'Carnage' ? 4 : 0,
    pointHoverRadius: 6
  }));

  if (charts.radar) { charts.radar.destroy(); }
  charts.radar = new Chart(document.getElementById('radarChart'), {
    type: 'radar',
    data: { labels: DATA.pillars, datasets },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      scales: {
        r: {
          min: 0, max: 100,
          ticks: { stepSize: 25, color: tickColor, backdropColor: 'transparent' },
          grid: { color: gridColor },
          angleLines: { color: gridColor },
          pointLabels: { color: '#a3a3a3', font: { weight: '600', size: 10 } }
        }
      },
      plugins: {
        legend: { display: false },
        tooltip: { backgroundColor: '#0a0a0a', borderColor: '#2d2d2d', borderWidth: 1 }
      }
    }
  });

  const leg = document.getElementById('radar-legend');
  leg.innerHTML = brands.map(b =>
    `<div class="legend-item"><div class="legend-dot" style="background:${b.color}"></div>${b.name}</div>`
  ).join('');
}

function buildBar() {
  const brands = filteredBrands();
  const labels = brands.map(b => b.name);
  
  if (charts.bar) { charts.bar.destroy(); }
  charts.bar = new Chart(document.getElementById('barChart'), {
    type: 'bar',
    data: {
      labels,
      datasets: [
        { label: 'Instagram', data: brands.map(b => b.sentimentIG[0]), backgroundColor: '#e8341c' },
        { label: 'TikTok', data: brands.map(b => b.sentimentTT[0]), backgroundColor: '#ffffff' },
        { label: 'Flagship Store', data: brands.map(b => b.sentimentStore[0]), backgroundColor: '#525252' }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      scales: {
        x: { grid: { display: false }, ticks: { color: '#ffffff' } },
        y: { min: 0, max: 100, grid: { color: gridColor }, ticks: { color: tickColor } }
      },
      plugins: {
        legend: { position: 'top', align: 'end', labels: { boxWidth: 12, color: '#ffffff' } }
      }
    }
  });
}

function buildBubble() {
  const brands = filteredBrands();
  const datasets = brands.map(b => ({
    label: b.name,
    data: [{ x: b.bubble.x, y: b.bubble.y, r: b.bubble.r }],
    backgroundColor: b.name === 'Carnage' ? 'rgba(232, 52, 28, 0.2)' : 'rgba(255,255,255,0.03)',
    borderColor: b.color,
    borderWidth: b.name === 'Carnage' ? 2.5 : 1
  }));

  if (charts.bubble) { charts.bubble.destroy(); }
  charts.bubble = new Chart(document.getElementById('bubbleChart'), {
    type: 'bubble',
    data: { datasets },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      scales: {
        x: {
          min: 0, max: 100,
          grid: { color: gridColor },
          ticks: { color: tickColor, callback: v => ['Entry','','','','Mid-Tier','','','','','Premium',''][Math.round(v/10)] || '' },
          title: { display: true, text: 'PRICING ARCHITECTURE', color: '#737373', font: { size: 10, weight: '700' } }
        },
        y: {
          min: 0, max: 100,
          grid: { color: gridColor },
          ticks: { color: tickColor, callback: v => v === 0 ? 'PERFORMANCE' : v === 50 ? 'HYBRID' : v === 100 ? 'LIFESTYLE' : '' },
          title: { display: true, text: 'APPLICATION FOCUS', color: '#737373', font: { size: 10, weight: '700' } }
        }
      },
      plugins: {
        legend: { display: false }
      }
    },
    plugins: [{
      id: 'starkLabels',
      afterDatasetsDraw(chart) {
        const { ctx } = chart;
        chart.data.datasets.forEach((ds, i) => {
          const meta = chart.getDatasetMeta(i);
          if (!meta.hidden && meta.data.length) {
            const pt = meta.data[0];
            ctx.save();
            ctx.fillStyle = ds.label === 'Carnage' ? '#e8341c' : '#ffffff';
            ctx.font = '900 11px Inter, sans-serif';
            ctx.textAlign = 'center';
            ctx.fillText(ds.label.toUpperCase(), pt.x, pt.y + 3);
            ctx.restore();
          }
        });
      }
    }]
  });
}

function buildTable() {
  const brands = filteredBrands();
  const nsiPill = n => n >= 70 ? `<span class="pill pill-green">+${n}</span>` : `<span class="pill pill-yellow">+${n}</span>`;
  const communityPill = c => c === 'High' ? `<span class="pill pill-green">${c}</span>` : `<span class="pill pill-yellow">${c}</span>`;

  document.getElementById('table-body').innerHTML = brands.map(b => `
    <tr>
      <td><div class="brand-name-cell">${b.name}</div></td>
      <td>${b.category}</td>
      <td>${b.priceTier}</td>
      <td>${nsiPill(b.nsi)}</td>
      <td style="color:#fff; font-weight:600;">${b.followers}</td>
      <td>${communityPill(b.community)}</td>
      <td>${b.positioning}</td>
    </tr>
  `).join('');
}

function setView(v) {
  currentView = v;
  document.getElementById('btn-global').classList.toggle('active', v === 'global');
  document.getElementById('btn-domestic').classList.toggle('active', v === 'domestic');
  buildAll();
}

function buildAll() {
  buildRadar();
  buildBar();
  buildBubble();
  buildTable();
}

buildAll();
</script>
</body>
</html>
